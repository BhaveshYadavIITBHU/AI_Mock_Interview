// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// 1. User Model 
// (Required because Interview references it)
// ------------------------------------------------------
model User {
  id         String      @id @default(uuid())
  googleId   String      @unique  // Restored for Google OAuth!
  email      String      @unique
  name       String?
  avatar     String?     // Helpful if you are saving Google profile pics
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  
  interviews Interview[] // Links to the interviews table
}

// ------------------------------------------------------
// 2. Interview Model
// ------------------------------------------------------
model Interview {
  id          String     @id @default(uuid())
  userId      String
  topic       String
  difficulty  String
  score       Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relationships
  user        User       @relation(fields: [userId], references: [id])
  questions   Question[]
}

// ------------------------------------------------------
// 3. Question Model
// ------------------------------------------------------
model Question {
  id          String    @id @default(uuid())
  interviewId String
  
  // Fields generated by the AI 
  type        String    // "mcq" or "text"
  text        String    // The actual question text
  options     String[]  // Array of 4 options (Native to PostgreSQL)
  
  // Note: I renamed 'userAnswer' to 'answer' to perfectly match 
  // the backend logic we just wrote, preventing future crashes!
  answer      String    @default("") 
  status      String    @default("not_visited") 

  //  Your grading & feedback fields 
  aiFeedback  String?   
  rating      Int?      

  // Relationships
  // Added onDelete: Cascade so if an interview is deleted, its questions are cleaned up automatically
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
}